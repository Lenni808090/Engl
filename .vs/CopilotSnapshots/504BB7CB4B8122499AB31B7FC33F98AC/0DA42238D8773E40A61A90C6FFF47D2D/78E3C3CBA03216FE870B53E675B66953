<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Physiotherapiepraxis – Onepager</title>
    <style>
        :root {
            --bg: #fcfaf8;
            --text: #3f3a36;
            --muted: #726b66;
            --primary: #b7d7d2;
            --primary-dark: #8cb9b2;
            --accent: #f3d8d8;
            --soft-beige: #f5efe9;
            --soft-gray: #F3F4EF;
            --card: #ffffff;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
            --radius: 22px;
            --max: 1180px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }

        img {
            max-width: 100%;
            display: block;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .container {
            width: min(92%, var(--max));
            margin: 0 auto;
        }

        /* Header */
        header {
            position: sticky;
            top: 0;
            z-index: 50;
            background: rgba(252, 250, 248, 0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 14px;
        }

            .logo img {
                height: 56px;
                width: auto;
                object-fit: contain;
            }

        .logo-text {
            display: flex;
            flex-direction: column;
        }

            .logo-text strong {
                font-size: 1.1rem;
                letter-spacing: 0.02em;
            }

            .logo-text span {
                font-size: 0.92rem;
                color: var(--muted);
            }

        nav {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
            font-size: 0.96rem;
            color: var(--muted);
        }

            nav a:hover {
                color: var(--text);
            }

        /* Hero */
        .hero {
            padding: 70px 0 50px;
            background: #FBF6F0;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.15fr 0.85fr;
            gap: 40px;
            align-items: center;
        }

        /* center the logo section horizontally */
        #logo .hero-grid {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* ensure the hero content is stacked and centered */
        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

            .hero-content h1 {
                font-size: clamp(2rem, 4vw, 3.4rem);
                line-height: 1.12;
                margin-bottom: 20px;
            }

            .hero-content p {
                font-size: 1.05rem;
                color: var(--muted);
                max-width: 58ch;
                margin-bottom: 28px;
            }

        .hero-buttons {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 22px;
            border-radius: 999px;
            font-weight: 600;
            transition: 0.2s ease;
        }

        .btn-primary {
            background: var(--primary);
            color: #243432;
        }

            .btn-primary:hover {
                background: var(--primary-dark);
            }

        .btn-secondary {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.08);
        }

            .btn-secondary:hover {
                background: #f8f8f8;
            }

        .hero-image-wrap {
            position: relative;
        }

        .hero-image {
            background: var(--soft-beige);
            border-radius: 32px;
            overflow: hidden;
            box-shadow: var(--shadow);
            min-height: 420px;
        }

            .hero-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Sections */
        section {
            padding: 70px 0;
        }

        .section-head {
            text-align: center;
            margin-bottom: 36px;
        }

            .section-head h2 {
                font-size: clamp(1.8rem, 3vw, 2.6rem);
                margin-bottom: 10px;
            }

            .section-head p {
                color: var(--muted);
                max-width: 70ch;
                margin: 0 auto;
            }

        /* Leistungen */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 22px;
        }

        .service-card {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 28px 22px;
            text-align: center;
            border: 1px solid rgba(0,0,0,0.04);
        }

        .service-icon {
            width: 200px;
            height: 200px;
            margin: 0 auto 0px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--soft-beige);
            border-radius: 50%;
            padding: 2px;
        }

        .service-card h3 {
            font-size: 1.08rem;
            margin-bottom: 10px;
        }

        .service-card p {
            color: var(--muted);
            font-size: 0.96rem;
        }

        /* Über uns */
        .about {
            background: var(--soft-gray);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 0.95fr 1.05fr;
            gap: 38px;
            align-items: center;
        }

        .about-images {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 18px;
        }

            .about-images img {
                aspect-ratio: 1 / 1;
                object-fit: cover;
                border-radius: 50%;
                box-shadow: var(--shadow);
                border: 6px solid #fff;
            }

        .about-text-card {
            background: rgba(255,255,255,0.7);
            border-radius: 28px;
            padding: 34px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        }

            .about-text-card h2 {
                margin-bottom: 16px;
                font-size: clamp(1.8rem, 3vw, 2.4rem);
            }

            .about-text-card p {
                color: var(--text);
                margin-bottom: 14px;
            }

                .about-text-card p:last-child {
                    margin-bottom: 0;
                }

        /* Zusatzinfos / Unterpunkte */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px;
        }

        .info-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 26px 24px;
        }

            .info-card h3 {
                margin-bottom: 12px;
                font-size: 1.08rem;
            }

            .info-card ul {
                padding-left: 18px;
                color: var(--muted);
            }

            .info-card li + li {
                margin-top: 8px;
            }


        /* Kontakt */
        .contact-box {
            background: linear-gradient(135deg, #ffffff 0%, #f7f2ee 100%);
            border-radius: 30px;
            padding: 34px;
            box-shadow: var(--shadow);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .contact-details h3,
        .contact-times h3 {
            margin-bottom: 14px;
            font-size: 1.2rem;
        }

        .contact-details p,
        .contact-times p {
            color: var(--muted);
            margin-bottom: 10px;
        }

        .contact-details strong {
            color: var(--text);
        }

        footer {
            padding: 28px 0 40px;
            color: var(--muted);
            font-size: 0.92rem;
            text-align: center;
        }

        /* Responsive */
        @media (max-width: 1050px) {
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .info-grid {
                grid-template-columns: 2fr;
            }
        }

        @media (max-width: 860px) {
            .hero-grid,
            .about-grid,
            .contact-box {
                grid-template-columns: 1fr;
            }

            nav {
                display: none;
            }

            .hero {
                padding-top: 40px;
            }

            .hero-image {
                min-height: 300px;
            }
        }

        @media (max-width: 600px) {
            .services-grid,
            .about-images {
                grid-template-columns: 1fr;
            }

            .header-inner {
                flex-direction: column;
                align-items: flex-start;
            }

            .about-images img {
                max-width: 280px;
                margin: 0 auto;
            }

            .about-text-card,
            .contact-box,
            .service-card,
            .info-card {
                padding: 22px;
            }
        }

        .rund {
            border-radius: 200px;
            -moz-border-radius: 200px;
            -webkit-border-radius: 200px;
            width: 200px;
            height: 200px;
            border: 3px solid white;
            -ms-align-content: inherit;
            -webkit-align-content: inherit;
            align-content: inherit;
            # This create the border
        }

        .team-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 16px 14px;
        }
    </style>
</head>
