.therapy-list {
    max-width: 900px;
    margin: 40px auto;
    font-family: Arial, sans-serif;
}

    .therapy-list ul {
        list-style: none;
        padding: 0;
        columns: 2; /* 2 Spalten für modernes Layout */
        column-gap: 40px;
    }

    .therapy-list li {
        position: relative;
        padding-left: 22px;
        margin-bottom: 10px;
        line-height: 1.6;
    }

        .therapy-list li::before {
            content: "";
            position: absolute;
            left: 0;
            top: 7px;
            width: 10px;
            height: 10px;
            border: 2px solid #2c3e50;
            border-radius: 2px;
        }

/* White circular container with wrapped text inside */
.aboutus_text {
    width: min(86vw, 900px);
    /* remove aspect-ratio so we can allow height to grow with content */
    border: 4px solid #ffffff;
    border-radius: 50%;
    padding: 6%;
    margin: 20px auto;
    background: rgba(255,255,255,0.02);
    color: #ffffff;
    box-sizing: border-box;
    overflow: hidden; /* hide overflow to keep circular look */
    text-align: left;
    line-height: 1.6;
    hyphens: auto;
    position: relative;
}

.aboutus_text .inner {
    /* use columns inside the inner box rather than the outer circular container */
    column-width: 320px;
    column-gap: 32px;
    height: 100%;
    overflow: auto; /* allow inner scrolling if needed */
}

.aboutus_text p {
    margin: 0 0 1em 0;
}

/* ensure the circular border stays visible without stretching too much on large screens */
@media (min-width: 1000px) {
    .aboutus_text {
        width: 900px;
    }
}

/* reduce columns on small screens */
@media (max-width: 700px) {
    .aboutus_text .inner {
        column-width: 260px;
        column-gap: 20px;
    }
}
